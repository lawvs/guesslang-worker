{
  "name": "guesslang-worker",
  "version": "0.1.0",
  "description": "A worker that uses guesslang's ML model to detect source code languages",
  "type": "module",
  "main": "src/index.ts",
  "license": "MIT",
  "scripts": {
    "dev": "wrangler dev src/index.ts",
    "dev:client": "vite",
    "build": "vite build",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typeCheck": "tsc --noEmit",
    "test": "vitest",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@tensorflow/tfjs-backend-cpu": "^3.21.0",
    "@tensorflow/tfjs-converter": "^3.21.0",
    "@tensorflow/tfjs-core": "^3.21.0",
    "hono": "^4.0.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260417.1",
    "@types/node": "^24.12.2",
    "@vscode/vscode-languagedetection": "git+https://github.com/microsoft/vscode-languagedetection.git",
    "prettier": "^3.2.5",
    "shiki": "^1.1.7",
    "typescript": "^6.0.3",
    "vite": "^5.1.4",
    "vitest": "^1.3.1",
    "wrangler": "^4.83.0"
  },
  "packageManager": "pnpm@10.33.0",
  "prettier": {}
}